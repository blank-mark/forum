rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }
    function isChatMember(chatId) {
      return signedIn() && exists(/databases/$(database)/documents/chats/$(chatId))
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if isOwner(userId);

      match /reposts/{postId} {
        allow read: if signedIn();
        allow create, update, delete: if isOwner(userId);
      }
    }

    match /posts/{postId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn();

      match /likes/{likeId} {
        allow read, create, update, delete: if signedIn();
      }

      match /comments/{commentId} {
        allow read, create, update, delete: if signedIn();

        match /likes/{likeId} {
          allow read, create, update, delete: if signedIn();
        }
      }
    }

    match /chats/{chatId} {
      allow read: if signedIn() && (!exists(/databases/$(database)/documents/chats/$(chatId)) || request.auth.uid in resource.data.members);
      allow create: if signedIn() && request.resource.data.members is list && request.auth.uid in request.resource.data.members;
      allow update, delete: if isChatMember(chatId);

      match /messages/{messageId} {
        allow read, create, update, delete: if isChatMember(chatId);
      }
    }
  }
}
